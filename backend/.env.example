# Kangaroo Shift — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Defaults below work out-of-the-box with `docker compose up`.
# Lines starting with # are optional — uncomment to override.

# ── Server ────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=debug

# ── Database (matches docker-compose defaults) ────────────────────────────
DATABASE_URL=postgresql+asyncpg://kangaroo:kangaroo@localhost:5432/kangaroo
DATABASE_SYNC_URL=postgresql://kangaroo:kangaroo@localhost:5432/kangaroo

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Meilisearch ───────────────────────────────────────────────────────────
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=kangaroo-dev-master-key

# ── Security (MUST change in staging/production) ──────────────────────────
SECRET_KEY=dev-secret-key-change-in-prod
JWT_SECRET_KEY=dev-jwt-secret-change-in-prod

# ── LLM API Keys (optional — leave commented for local-only mode) ────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AIza...

# ── Features ──────────────────────────────────────────────────────────────
LOCAL_MODE_ENABLED=true
PARALLEL_QUERIES_ENABLED=true
TEAM_FEATURES_ENABLED=false

# ── CORS ──────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
