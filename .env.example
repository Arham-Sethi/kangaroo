# =============================================================================
# Kangaroo Shift — Environment Variables
# Copy to .env and fill in values
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://kangaroo:kangaroo@localhost:5432/kangaroo
DATABASE_SYNC_URL=postgresql://kangaroo:kangaroo@localhost:5432/kangaroo
POSTGRES_USER=kangaroo
POSTGRES_PASSWORD=kangaroo
POSTGRES_DB=kangaroo

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Meilisearch ---
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=kangaroo-dev-master-key

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=true
LOG_LEVEL=debug
SECRET_KEY=change-me-in-production-use-a-long-random-string
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# --- JWT ---
JWT_SECRET_KEY=change-me-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Encryption ---
ENCRYPTION_KEY_DERIVATION_MEMORY=65536
ENCRYPTION_KEY_DERIVATION_TIME=3
ENCRYPTION_KEY_DERIVATION_PARALLELISM=4

# --- LLM API Keys ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# --- Feature Flags ---
LOCAL_MODE_ENABLED=true
PARALLEL_QUERIES_ENABLED=true
TEAM_FEATURES_ENABLED=false

# --- Object Storage ---
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage
# S3_BUCKET=
# S3_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Kangaroo Shift
